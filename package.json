{
  "name": "@vastra/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "node -e \"if (!process.env.CI && process.env.NODE_ENV !== 'production') import('husky').then(({default: husky}) => husky())\"",
    "dev": "next dev",
    "clean": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true})\"",
    "build": "npm run clean && next build",
    "start": "next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "precommit": "npm run format:check && npm run lint && npm run typecheck",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.80.7",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "15.5.19",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.9",
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "20.17.6",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "eslint": "^9.29.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.10",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
